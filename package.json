{
  "name": "sentinel-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "cd apps/api && python -m uvicorn app.main:app --reload --port 8000",
    "dev:backend": "pnpm --filter atomops-backend dev",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:backend\"",
    "build": "pnpm --filter web build && pnpm --filter atomops-backend build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
